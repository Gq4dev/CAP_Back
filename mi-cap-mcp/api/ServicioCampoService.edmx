        <Annotation Term="Common.Label" String="{i18n>Name}"/>
      </Annotations>
      <Annotations Target="ServicioCampoService.DisponibilidadTecnico_texts/descr">
        <Annotation Term="Common.Label" String="{i18n>Description}"/>
      </Annotations>
    </Schema>
  </edmx:DataServices>
</edmx:Edmx>
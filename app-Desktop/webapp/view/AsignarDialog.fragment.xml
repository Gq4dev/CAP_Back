<core:FragmentDefinition
  xmlns="sap.m"
  xmlns:core="sap.ui.core">
  <Dialog id="dlgAsignar" title="{i18n>dlgAsignarTitulo}" contentWidth="24rem" contentHeight="22rem">
    <List
      id="listTecnicos"
      mode="SingleSelectMaster"
      items="{
        path: '/Tecnicos',
        parameters: { $expand: 'disponibilidad' },
        filters: [{ path: 'disponibilidad_code', operator: 'NE', value1: 'AUSENTE' }],
        sorter: { path: 'Nombre' }
      }">
      <StandardListItem
        title="{Nombre}"
        description="{Zona}"
        info="{disponibilidad/name}"
        infoState="{ path: 'disponibilidad/criticidad', formatter: '.formatter.estadoState' }"
        icon="sap-icon://employee"/>
    </List>
    <beginButton>
      <Button text="{i18n>btnConfirmar}" type="Emphasized" press=".onConfirmarAsignar"/>
    </beginButton>
    <endButton>
      <Button text="{i18n>btnCancelar}" press=".onCancelarAsignar"/>
    </endButton>
  </Dialog>
</core:FragmentDefinition>

<mvc:View
  controllerName="fsm.desktop.controller.Crear"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc"
  xmlns:core="sap.ui.core"
  xmlns:form="sap.ui.layout.form">
  <Page id="pageCrear" title="{i18n>crearTitulo}" showNavButton="true" navButtonPress=".onCancelar">
    <content>
      <form:SimpleForm editable="true" layout="ColumnLayout" columnsM="1" columnsL="1" columnsXL="1" title="{i18n>crearSeccion}">
        <Label text="{i18n>lblCliente}" required="true"/>
        <Select id="selCliente" forceSelection="false" selectedKey="{form>/cliente_ID}" change=".onClienteChange" width="100%"
          items="{ path: '/Clientes', sorter: { path: 'Nombre' } }">
          <core:Item key="{ID}" text="{Nombre}"/>
        </Select>

        <Label text="{i18n>lblEquipo}"/>
        <ComboBox id="cbEquipo" selectedKey="{form>/equipo_ID}" width="100%"
          items="{ path: '/Equipos', sorter: { path: 'Descripcion' } }">
          <core:Item key="{ID}" text="{Descripcion}"/>
        </ComboBox>

        <Label text="{i18n>lblServicio}" required="true"/>
        <Select id="selServicio" forceSelection="false" selectedKey="{form>/tipoServicio_ID}" width="100%"
          items="{ path: '/CatalogoServicios', sorter: { path: 'Nombre' } }">
          <core:Item key="{ID}" text="{Nombre}"/>
        </Select>

        <Label text="{i18n>lblPrioridad}"/>
        <Select id="selPrioridad" selectedKey="{form>/prioridad_code}" width="100%"
          items="{ path: '/Prioridades', sorter: { path: 'nivel' } }">
          <core:Item key="{code}" text="{name}"/>
        </Select>

        <Label text="{i18n>lblDescripcion}" required="true"/>
        <TextArea id="taDesc" value="{form>/Descripcion}" rows="3" width="100%" growing="true"/>
      </form:SimpleForm>
    </content>

    <footer>
      <OverflowToolbar>
        <ToolbarSpacer/>
        <Button text="{i18n>btnGuardar}" type="Emphasized" icon="sap-icon://save" press=".onGuardar"/>
        <Button text="{i18n>btnCancelar}" press=".onCancelar"/>
      </OverflowToolbar>
    </footer>
  </Page>
</mvc:View>

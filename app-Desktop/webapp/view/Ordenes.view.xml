<mvc:View
  controllerName="fsm.desktop.controller.Ordenes"
  xmlns="sap.m"
  xmlns:mvc="sap.ui.core.mvc">
  <Page id="pageOrdenes" title="{i18n>tituloOrdenes}" showNavButton="true" navButtonPress=".onVolver">
    <content>
      <IconTabBar id="filtroEstados" select=".onFiltrarEstado" expandable="false" headerMode="Inline">
        <items>
          <IconTabFilter key="all" text="{i18n>tabTodas}" count="{counts>/all}"/>
          <IconTabSeparator/>
          <IconTabFilter key="nuevas" text="{i18n>tabNuevas}" count="{counts>/nuevas}" icon="sap-icon://create" iconColor="Default"/>
          <IconTabFilter key="activas" text="{i18n>tabActivas}" count="{counts>/activas}" icon="sap-icon://work-history" iconColor="Critical"/>
          <IconTabFilter key="cerradas" text="{i18n>tabCerradas}" count="{counts>/cerradas}" icon="sap-icon://sys-enter-2" iconColor="Positive"/>
        </items>
        <content>
          <Table
            id="tablaOrdenes"
            growing="true"
            growingThreshold="25"
            items="{
              path: '/OrdenesServicio',
              parameters: { $expand: 'estado,prioridad,tecnico,cliente,tipoServicio' },
              sorter: { path: 'FechaApertura', descending: true }
            }">
            <headerToolbar>
              <OverflowToolbar>
                <Title text="{i18n>tituloOrdenes}" level="H2"/>
                <ToolbarSpacer/>
                <SearchField width="20rem" placeholder="{i18n>buscarPlaceholder}" search=".onBuscar"/>
                <Button icon="sap-icon://refresh" tooltip="{i18n>refrescar}" press=".onRefrescar"/>
              </OverflowToolbar>
            </headerToolbar>
            <columns>
              <Column><Text text="{i18n>colNumero}"/></Column>
              <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colCliente}"/></Column>
              <Column minScreenWidth="Desktop" demandPopin="true"><Text text="{i18n>colServicio}"/></Column>
              <Column><Text text="{i18n>colEstado}"/></Column>
              <Column><Text text="{i18n>colPrioridad}"/></Column>
              <Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colTecnico}"/></Column>
              <Column hAlign="End" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colSLA}"/></Column>
            </columns>
            <items>
              <ColumnListItem type="Navigation" press=".onAbrirOrden">
                <cells>
                  <ObjectIdentifier title="{Numero}" text="{Descripcion}"/>
                  <Text text="{cliente/Nombre}"/>
                  <Text text="{tipoServicio/Nombre}"/>
                  <ObjectStatus
                    text="{estado/name}"
                    state="{ path: 'estado/criticidad', formatter: '.formatter.estadoState' }"
                    inverted="true"/>
                  <ObjectStatus
                    text="{prioridad/name}"
                    state="{ path: 'prioridad/criticidad', formatter: '.formatter.estadoState' }"/>
                  <Text text="{= ${tecnico/Nombre} || ${i18n>sinTecnico} }"/>
                  <Text text="{
                    path: 'FechaCompromiso',
                    type: 'sap.ui.model.odata.type.DateTimeOffset',
                    formatOptions: { style: 'short' }
                  }"/>
                </cells>
              </ColumnListItem>
            </items>
          </Table>
        </content>
      </IconTabBar>
    </content>
  </Page>
</mvc:View>
